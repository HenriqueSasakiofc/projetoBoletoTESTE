{
    "name": "projeto-boleto/backend",
    "description": "Backend do Projeto Boleto em PHP",
    "type": "project",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0",
        "illuminate/events": "^11.0",
        "phpoffice/phpspreadsheet": "^3.0",
        "vlucas/phpdotenv": "^5.6",
        "bramus/router": "~1.6",
        "firebase/php-jwt": "^6.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Config\\": "config/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
